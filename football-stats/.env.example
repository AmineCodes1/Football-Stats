# API-Football (via RapidAPI)
# Get your key at: https://rapidapi.com/api-sports/api/api-football
RAPIDAPI_KEY=your_rapidapi_key_here

# MongoDB connection string
# MongoDB Atlas example: mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/
# Local Docker example: mongodb://admin:password@localhost:27017/
MONGODB_URI=mongodb://admin:password@localhost:27017/
MONGODB_DB=football_stats

# Default league and season
# 39 = English Premier League, 140 = La Liga, 135 = Serie A, 78 = Bundesliga
DEFAULT_LEAGUE_ID=39
DEFAULT_SEASON=2024
